pkgname=wellbeing-git
pkgver=r1.abc1234
pkgrel=1
pkgdesc="Desktop app for tracking screen time and app usage (git version)"
arch=('x86_64')
url="https://github.com/Azlaneh/wellbeing"
license=('MIT')
depends=(
    'webkit2gtk-4.1'
    'gtk3'
    'libappindicator-gtk3'
    'librsvg'
    'libayatana-appindicator'
    'appmenu-gtk-module'
)
makedepends=(
    'rust'
    'cargo'
    'nodejs'
    'npm'
    'pkg-config'
    'openssl'
    'libappindicator-gtk3'
    'librsvg'
    'git'
)
optdepends=(
    'libnotify: desktop notifications'
)
provides=('wellbeing')
conflicts=('wellbeing' 'wellbeing-bin')
source=("git+https://github.com/Azlaneh/wellbeing.git")
sha256sums=('SKIP')

pkgver() {
    cd "$srcdir/wellbeing"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
    cd "$srcdir/wellbeing"

    # Install npm dependencies
    npm install --prefer-offline
}

build() {
    cd "$srcdir/wellbeing"

    # Unset makepkg flags that break Rust/C build scripts:
    # - RUSTFLAGS: injects --remap-path-prefix which corrupts bundled sqlite3/ring linking
    # - CFLAGS: -flto=auto causes LTO object files to conflict with bundled static libs
    # - LDFLAGS: may reference flags incompatible with cargo's linker invocation
    export RUSTFLAGS=""
    export CFLAGS=""
    export CXXFLAGS=""
    export LDFLAGS=""

    # Use tauri build so the frontend bundle is embedded (not a devUrl connection)
    npm run tauri -- build --no-bundle
}

package() {
    cd "$srcdir/wellbeing"

    # Install binary
    install -Dm755 "src-tauri/target/release/wellbeing" "$pkgdir/usr/bin/wellbeing"

    # Install desktop file
    install -Dm644 "pkg/linux/arch/wellbeing.desktop" "$pkgdir/usr/share/applications/wellbeing.desktop"

    # Install icons
    install -Dm644 "src-tauri/icons/32x32.png" "$pkgdir/usr/share/icons/hicolor/32x32/apps/wellbeing.png"
    install -Dm644 "src-tauri/icons/128x128.png" "$pkgdir/usr/share/icons/hicolor/128x128/apps/wellbeing.png"
    install -Dm644 "src-tauri/icons/128x128@2x.png" "$pkgdir/usr/share/icons/hicolor/256x256/apps/wellbeing.png"
    install -Dm644 "src-tauri/icons/icon.png" "$pkgdir/usr/share/icons/hicolor/512x512/apps/wellbeing.png"

    # Install license
    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null || true
}
